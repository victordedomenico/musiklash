{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@klash/auth": ["../../packages/auth/src/index.ts"],
      "@klash/auth/guest": ["../../packages/auth/src/guest.ts"],
      "@klash/auth/supabase": ["../../packages/auth/src/supabase.ts"],
      "@klash/i18n": ["../../packages/i18n/src/index.ts"],
      "@klash/game-engine": ["../../packages/game-engine/src/index.ts"],
      "@klash/content-adapter": ["../../packages/content-adapter/src/index.ts"],
      "@klash/klash-config": ["../../packages/klash-config/src/index.ts"],
      "@klash/klash-app/*": ["../../packages/klash-app/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
