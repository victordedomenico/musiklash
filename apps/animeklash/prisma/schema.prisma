generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppRole {
  admin
  moderator
  user

  @@map("app_role")
}

model Profile {
  id        String        @id @db.Uuid
  username  String        @unique
  role      AppRole       @default(user)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz

  brackets                  Bracket[]
  games                     BracketGame[]
  tierlists                 Tierlist[]
  tierlistSessions          TierlistSession[]
  blindtests                Blindtest[]
  blindtestSessions         BlindtestSession[]
  soloSessions              BattleFeatSoloSession[]
  soloChallenges            BattleFeatSoloChallenge[]
  hostedRooms               BattleFeatRoom[]        @relation("RoomHost")
  hostedBlindtestRooms      BlindtestRoom[]         @relation("BlindtestRoomHost")
  streamClashes             StreamClash[]
  streamClashSessions       StreamClashSession[]
  hostedStreamClashRooms    StreamClashRoom[]       @relation("StreamClashRoomHost")
  smashPasses               SmashPass[]
  smashPassSessions         SmashPassSession[]
  hostedSmashPassRooms      SmashPassRoom[]         @relation("SmashPassRoomHost")

  @@map("profiles")
}

model Bracket {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId    String   @map("owner_id") @db.Uuid
  title      String
  theme      String?
  size       Int      @db.SmallInt
  visibility String   @default("private")
  coverUrl   String?  @map("cover_url")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  owner  Profile        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tracks BracketTrack[]
  games  BracketGame[]

  @@index([ownerId])
  @@index([visibility, createdAt(sort: Desc)])
  @@map("brackets")
}

model BracketTrack {
  bracketId  String  @map("bracket_id") @db.Uuid
  seed       Int     @db.SmallInt
  externalId String  @map("external_id")
  source     String  @default("anilist")
  title      String
  artist     String
  previewUrl String  @map("preview_url")
  coverUrl   String? @map("cover_url")
  metadata   Json?   @db.JsonB

  bracket Bracket @relation(fields: [bracketId], references: [id], onDelete: Cascade)

  @@id([bracketId, seed])
  @@map("bracket_tracks")
}

model BracketGame {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bracketId    String   @map("bracket_id") @db.Uuid
  playerId     String?  @map("player_id") @db.Uuid
  currentRound Int      @default(1) @map("current_round") @db.SmallInt
  winnerSeed   Int?     @map("winner_seed") @db.SmallInt
  visibility   String   @default("private")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  bracket Bracket       @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  player  Profile?      @relation(fields: [playerId], references: [id], onDelete: SetNull)
  votes   BracketVote[]

  @@index([bracketId])
  @@index([playerId])
  @@index([visibility, createdAt(sort: Desc)])
  @@map("bracket_games")
}

model BracketVote {
  gameId     String   @map("game_id") @db.Uuid
  round      Int      @db.SmallInt
  matchIndex Int      @map("match_index") @db.SmallInt
  winnerSeed Int      @map("winner_seed") @db.SmallInt
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  game BracketGame @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([gameId, round, matchIndex])
  @@map("bracket_votes")
}

// ─── Blindtests ───────────────────────────────────────────────────────────────

model Blindtest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId    String   @map("owner_id") @db.Uuid
  title      String
  visibility String   @default("private")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  owner    Profile            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tracks   BlindtestTrack[]
  sessions BlindtestSession[]
  rooms    BlindtestRoom[]

  @@index([ownerId])
  @@index([visibility, createdAt(sort: Desc)])
  @@map("blindtests")
}

model BlindtestRoom {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blindtestId     String    @map("blindtest_id") @db.Uuid
  hostId          String    @map("host_id") @db.Uuid
  visibility      String    @default("private")
  status          String    @default("waiting") // waiting | playing | finished
  currentTrack    Int       @default(0) @map("current_track") @db.SmallInt
  participants    Json      @default("[]") @db.JsonB
  winnerId        String?   @map("winner_id") @db.Uuid
  trackStartedAt  DateTime? @map("track_started_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  blindtest Blindtest @relation(fields: [blindtestId], references: [id], onDelete: Cascade)
  host      Profile   @relation("BlindtestRoomHost", fields: [hostId], references: [id])

  @@index([hostId])
  @@index([blindtestId])
  @@index([visibility, status, updatedAt(sort: Desc)])
  @@map("blindtest_rooms")
}

model BlindtestTrack {
  blindtestId String  @map("blindtest_id") @db.Uuid
  position    Int     @db.SmallInt
  externalId  String  @map("external_id")
  source      String  @default("anilist")
  title       String
  artist      String
  previewUrl  String  @map("preview_url")
  coverUrl    String? @map("cover_url")
  metadata    Json?   @db.JsonB

  blindtest Blindtest @relation(fields: [blindtestId], references: [id], onDelete: Cascade)

  @@id([blindtestId, position])
  @@map("blindtest_tracks")
}

model BlindtestSession {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  blindtestId String   @map("blindtest_id") @db.Uuid
  playerId    String?  @map("player_id") @db.Uuid
  score       Int      @default(0)
  maxScore    Int      @map("max_score") @default(0)
  answers     Json     @db.JsonB
  visibility  String   @default("private")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  blindtest Blindtest @relation(fields: [blindtestId], references: [id], onDelete: Cascade)
  player    Profile?  @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([blindtestId])
  @@index([visibility, createdAt(sort: Desc)])
  @@map("blindtest_sessions")
}

// ─── Tierlists ────────────────────────────────────────────────────────────────

model Tierlist {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId    String   @map("owner_id") @db.Uuid
  title      String
  theme      String?
  visibility String   @default("private")
  coverUrl   String?  @map("cover_url")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  owner    Profile           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tracks   TierlistTrack[]
  sessions TierlistSession[]

  @@index([ownerId])
  @@index([visibility, createdAt(sort: Desc)])
  @@map("tierlists")
}

model TierlistTrack {
  tierlistId String  @map("tierlist_id") @db.Uuid
  position   Int     @db.SmallInt
  externalId String  @map("external_id")
  source     String  @default("anilist")
  title      String
  artist     String
  previewUrl String  @map("preview_url")
  coverUrl   String? @map("cover_url")
  metadata   Json?   @db.JsonB

  tierlist Tierlist @relation(fields: [tierlistId], references: [id], onDelete: Cascade)

  @@id([tierlistId, position])
  @@map("tierlist_tracks")
}

// Stores the tier placements for one play session.
// placements: { "S+": [0,2], "S": [1], "A": [3], ... } — array of track positions
model TierlistSession {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tierlistId String   @map("tierlist_id") @db.Uuid
  playerId   String?  @map("player_id") @db.Uuid
  placements Json     @db.JsonB
  visibility String   @default("private")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  tierlist Tierlist @relation(fields: [tierlistId], references: [id], onDelete: Cascade)
  player   Profile? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([tierlistId])
  @@index([visibility, createdAt(sort: Desc)])
  @@map("tierlist_sessions")
}

// ─── BattleClash character graph (AniList co-appearances cache) ───────────────

model AnimeCharacter {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId     String   @unique @map("external_id")
  name           String
  nameSlug       String   @map("name_slug")
  popularityTier Int      @default(3) @map("popularity_tier") @db.SmallInt
  favourites     Int      @default(0)
  pictureUrl     String?  @map("picture_url")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  coappearancesAsA CharacterCoappearance[] @relation("CoappA")
  coappearancesAsB CharacterCoappearance[] @relation("CoappB")

  @@index([nameSlug])
  @@map("anime_characters")
}

model CharacterCoappearance {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  characterAId    String  @map("character_a_id") @db.Uuid
  characterBId    String  @map("character_b_id") @db.Uuid
  animeExternalId String? @map("anime_external_id")
  animeTitle      String? @map("anime_title")

  characterA AnimeCharacter @relation("CoappA", fields: [characterAId], references: [id], onDelete: Cascade)
  characterB AnimeCharacter @relation("CoappB", fields: [characterBId], references: [id], onDelete: Cascade)

  @@unique([characterAId, characterBId, animeExternalId])
  @@index([characterAId])
  @@index([characterBId])
  @@map("character_coappearances")
}

// ─── BattleFeat ───────────────────────────────────────────────────────────────

model BattleFeatSoloSession {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playerId         String?  @map("player_id") @db.Uuid
  challengeId      String?  @map("challenge_id") @db.Uuid
  difficulty       Int      @db.SmallInt
  startingArtistId String   @map("starting_artist_id")
  moves            Json     @default("[]") @db.JsonB
  score            Int      @default(0)
  jokersUsed       Int      @default(0) @map("jokers_used")
  status           String   @default("active")
  visibility       String   @default("private")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  player    Profile?                 @relation(fields: [playerId], references: [id], onDelete: SetNull)
  challenge BattleFeatSoloChallenge? @relation(fields: [challengeId], references: [id], onDelete: SetNull)

  @@index([playerId])
  @@index([challengeId])
  @@index([visibility, createdAt(sort: Desc)])
  @@index([difficulty, score(sort: Desc)])
  @@map("battle_feat_solo_sessions")
}

model BattleFeatSoloChallenge {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId            String   @map("owner_id") @db.Uuid
  title              String
  difficulty         Int      @db.SmallInt
  startingArtistId   String   @map("starting_artist_id")
  startingArtistName String   @map("starting_artist_name")
  startingArtistPic  String?  @map("starting_artist_pic")
  visibility         String   @default("private")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  owner    Profile                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sessions BattleFeatSoloSession[]

  @@index([ownerId])
  @@index([visibility, createdAt(sort: Desc)])
  @@map("battle_feat_solo_challenges")
}

model BattleFeatRoom {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hostId             String   @map("host_id") @db.Uuid
  status             String   @default("waiting")
  startingArtistId   String?  @map("starting_artist_id")
  startingArtistName String?  @map("starting_artist_name")
  startingArtistPic  String?  @map("starting_artist_pic")
  currentArtistId    String?  @map("current_artist_id")
  currentArtistName  String?  @map("current_artist_name")
  currentArtistPic   String?  @map("current_artist_pic")
  currentTurnId      String?  @map("current_turn_id") @db.Uuid
  usedArtistIds      Json     @default("[]") @map("used_artist_ids") @db.JsonB
  moves              Json     @default("[]") @db.JsonB
  participants       Json     @default("[]") @db.JsonB
  winnerId           String?  @map("winner_id") @db.Uuid
  visibility         String   @default("private")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz

  host Profile @relation("RoomHost", fields: [hostId], references: [id])

  @@index([hostId])
  @@index([visibility, createdAt(sort: Desc)])
  @@map("battle_feat_rooms")
}

// ─── Stream Clash ─────────────────────────────────────────────────────────────

model StreamClash {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId    String   @map("owner_id") @db.Uuid
  title      String
  visibility String   @default("private")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  owner    Profile              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tracks   StreamClashTrack[]
  rooms    StreamClashRoom[]
  sessions StreamClashSession[]

  @@index([ownerId])
  @@index([visibility, createdAt(sort: Desc)])
  @@map("stream_clashes")
}

model StreamClashTrack {
  streamClashId String  @map("stream_clash_id") @db.Uuid
  position      Int     @db.SmallInt
  externalId    String  @map("external_id")
  source        String  @default("anilist")
  title         String
  artist        String
  previewUrl    String  @map("preview_url")
  coverUrl      String? @map("cover_url")
  rank          Int     @default(0)
  metadata      Json?   @db.JsonB

  streamClash StreamClash @relation(fields: [streamClashId], references: [id], onDelete: Cascade)

  @@id([streamClashId, position])
  @@map("stream_clash_tracks")
}

model StreamClashSession {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  streamClashId String   @map("stream_clash_id") @db.Uuid
  playerId      String?  @map("player_id") @db.Uuid
  difficulty    String   @default("easy") // easy | normal | hard
  score         Int      @default(0)
  totalRounds   Int      @default(0) @map("total_rounds")
  rounds        Json     @default("[]") @db.JsonB
  visibility    String   @default("private")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  streamClash StreamClash @relation(fields: [streamClashId], references: [id], onDelete: Cascade)
  player      Profile?    @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([streamClashId])
  @@index([playerId])
  @@index([visibility, createdAt(sort: Desc)])
  @@map("stream_clash_sessions")
}

model StreamClashRoom {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  streamClashId   String    @map("stream_clash_id") @db.Uuid
  hostId          String    @map("host_id") @db.Uuid
  status          String    @default("waiting") // waiting | playing | finished
  visibility      String    @default("private")
  difficulty      String    @default("easy") // easy | normal | hard
  currentRound    Int       @default(0) @map("current_round") @db.SmallInt
  totalRounds     Int       @default(10) @map("total_rounds") @db.SmallInt
  currentPair     Json?     @map("current_pair") @db.JsonB
  pairStartedAt   DateTime? @map("pair_started_at") @db.Timestamptz
  participants    Json      @default("[]") @db.JsonB
  winnerId        String?   @map("winner_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  streamClash StreamClash @relation(fields: [streamClashId], references: [id], onDelete: Cascade)
  host        Profile     @relation("StreamClashRoomHost", fields: [hostId], references: [id])

  @@index([hostId])
  @@index([streamClashId])
  @@index([visibility, status, updatedAt(sort: Desc)])
  @@map("stream_clash_rooms")
}

// ─── Smash or Pass ────────────────────────────────────────────────────────────

model SmashPass {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId    String   @map("owner_id") @db.Uuid
  title      String
  itemType   String   @map("item_type")
  visibility String   @default("private")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  owner    Profile            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items    SmashPassItem[]
  sessions SmashPassSession[]
  rooms    SmashPassRoom[]

  @@index([ownerId])
  @@index([visibility, createdAt(sort: Desc)])
  @@map("smash_passes")
}

model SmashPassItem {
  smashPassId String  @map("smash_pass_id") @db.Uuid
  position    Int     @db.SmallInt
  externalId  String  @map("external_id")
  source      String  @default("anilist")
  title       String
  subtitle    String?
  coverUrl    String? @map("cover_url")
  previewUrl  String? @map("preview_url")
  tags        Json    @default("[]") @db.JsonB
  description String?
  metadata    Json?   @db.JsonB

  smashPass SmashPass @relation(fields: [smashPassId], references: [id], onDelete: Cascade)

  @@id([smashPassId, position])
  @@map("smash_pass_items")
}

model SmashPassItemStats {
  itemType   String   @map("item_type")
  externalId String   @map("external_id")
  source     String   @default("anilist")
  smashCount BigInt   @default(0) @map("smash_count")
  passCount  BigInt   @default(0) @map("pass_count")
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@id([itemType, externalId])
  @@map("smash_pass_item_stats")
}

model SmashPassSession {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  smashPassId String   @map("smash_pass_id") @db.Uuid
  playerId    String?  @map("player_id") @db.Uuid
  smashCount  Int      @default(0) @map("smash_count")
  passCount   Int      @default(0) @map("pass_count")
  choices     Json     @default("[]") @db.JsonB
  visibility  String   @default("private")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  smashPass SmashPass @relation(fields: [smashPassId], references: [id], onDelete: Cascade)
  player    Profile?  @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([smashPassId])
  @@index([playerId])
  @@index([visibility, createdAt(sort: Desc)])
  @@map("smash_pass_sessions")
}

model SmashPassRoom {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  smashPassId       String    @map("smash_pass_id") @db.Uuid
  hostId            String    @map("host_id") @db.Uuid
  status            String    @default("waiting") // waiting | playing | finished
  visibility        String    @default("private")
  currentPosition   Int       @default(0) @map("current_position") @db.SmallInt
  participants      Json      @default("[]") @db.JsonB
  winnerId          String?   @map("winner_id") @db.Uuid
  positionStartedAt DateTime? @map("position_started_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  smashPass SmashPass @relation(fields: [smashPassId], references: [id], onDelete: Cascade)
  host      Profile   @relation("SmashPassRoomHost", fields: [hostId], references: [id])

  @@index([hostId])
  @@index([smashPassId])
  @@index([visibility, status, updatedAt(sort: Desc)])
  @@map("smash_pass_rooms")
}
