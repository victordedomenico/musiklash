{
  "name": "klash-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "dev:musiklash": "turbo run dev --filter=musiklash",
    "dev:animeklash": "turbo run dev --filter=animeklash",
    "build": "turbo run build",
    "build:musiklash": "turbo run build --filter=musiklash",
    "build:animeklash": "turbo run build --filter=animeklash",
    "build:demoklash": "turbo run build --filter=demoklash",
    "dev:demoklash": "turbo run dev --filter=demoklash",
    "dev:screenklash": "turbo run dev --filter=screenklash",
    "build:screenklash": "turbo run build --filter=screenklash",
    "dev:mangaklash": "turbo run dev --filter=mangaklash",
    "build:mangaklash": "turbo run build --filter=mangaklash",
    "dev:bookklash": "turbo run dev --filter=bookklash",
    "build:bookklash": "turbo run build --filter=bookklash",
    "dev:comicklash": "turbo run dev --filter=comicklash",
    "build:comicklash": "turbo run build --filter=comicklash",
    "dev:gameklash": "turbo run dev --filter=gameklash",
    "build:gameklash": "turbo run build --filter=gameklash",
    "dev:boardklash": "turbo run dev --filter=boardklash",
    "build:boardklash": "turbo run build --filter=boardklash",
    "dev:cardklash": "turbo run dev --filter=cardklash",
    "build:cardklash": "turbo run build --filter=cardklash",
    "dev:esportklash": "turbo run dev --filter=esportklash",
    "build:esportklash": "turbo run build --filter=esportklash",
    "dev:legoklash": "turbo run dev --filter=legoklash",
    "build:legoklash": "turbo run build --filter=legoklash",
    "dev:pokeklash": "turbo run dev --filter=pokeklash",
    "build:pokeklash": "turbo run build --filter=pokeklash",
    "dev:tasteklash": "turbo run dev --filter=tasteklash",
    "build:tasteklash": "turbo run build --filter=tasteklash",
    "dev:worldklash": "turbo run dev --filter=worldklash",
    "build:worldklash": "turbo run build --filter=worldklash",
    "dev:petklash": "turbo run dev --filter=petklash",
    "build:petklash": "turbo run build --filter=petklash",
    "dev:sportklash": "turbo run dev --filter=sportklash",
    "build:sportklash": "turbo run build --filter=sportklash",
    "dev:tennisklash": "turbo run dev --filter=tennisklash",
    "build:tennisklash": "turbo run build --filter=tennisklash",
    "dev:footklash": "turbo run dev --filter=footklash",
    "build:footklash": "turbo run build --filter=footklash",
    "dev:fightklash": "turbo run dev --filter=fightklash",
    "build:fightklash": "turbo run build --filter=fightklash",
    "dev:basketklash": "turbo run dev --filter=basketklash",
    "build:basketklash": "turbo run build --filter=basketklash",
    "dev:fitnessklash": "turbo run dev --filter=fitnessklash",
    "build:fitnessklash": "turbo run build --filter=fitnessklash",
    "dev:f1klash": "turbo run dev --filter=f1klash",
    "build:f1klash": "turbo run build --filter=f1klash",
    "dev:rapklash": "turbo run dev --filter=rapklash",
    "build:rapklash": "turbo run build --filter=rapklash",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "scaffold:vertical": "tsx scripts/scaffold-klash-vertical.ts",
    "db:start": "pnpm --filter=musiklash run db:start",
    "db:stop": "pnpm --filter=musiklash run db:stop",
    "db:status": "pnpm --filter=musiklash run db:status",
    "db:reset": "pnpm --filter=musiklash run db:reset",
    "db:up": "pnpm --filter=musiklash run db:up",
    "db:migrate": "pnpm --filter=musiklash run db:migrate",
    "db:start:animeklash": "pnpm --filter=animeklash run db:start",
    "db:stop:animeklash": "pnpm --filter=animeklash run db:stop",
    "db:status:animeklash": "pnpm --filter=animeklash run db:status",
    "db:reset:animeklash": "pnpm --filter=animeklash run db:reset",
    "db:up:animeklash": "pnpm --filter=animeklash run db:up",
    "db:migrate:animeklash": "pnpm --filter=animeklash run db:migrate"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.5.8"
  }
}
