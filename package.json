{
  "name": "klash-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w musiklash",
    "dev:musiklash": "npm run dev -w musiklash",
    "dev:animeklash": "npm run dev -w animeklash",
    "build": "npm run build --workspaces --if-present",
    "build:musiklash": "npm run build -w musiklash",
    "build:animeklash": "npm run build -w animeklash",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
