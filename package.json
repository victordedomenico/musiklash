{
  "name": "klash-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=musiklash",
    "dev:musiklash": "turbo run dev --filter=musiklash",
    "dev:animeklash": "turbo run dev --filter=animeklash",
    "build": "turbo run build",
    "build:musiklash": "turbo run build --filter=musiklash",
    "build:animeklash": "turbo run build --filter=animeklash",
    "build:demoklash": "turbo run build --filter=demoklash",
    "dev:demoklash": "turbo run dev --filter=demoklash",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  }
}
